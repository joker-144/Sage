# Sage — 学术论文写作辅助系统配置模板
# 复制此文件为 .env 并填入你的 API Key，然后运行 `sage chat`
#
# 快速开始：
#   cp .env.example .env
#   # 编辑 .env，至少填 LLM_CHAT_API_KEY
#   sage chat

# ── 对话 LLM 配置 ──
# DeepSeek（默认推荐）— https://platform.deepseek.com/api_keys
LLM_CHAT_API_KEY=your-deepseek-api-key-here
LLM_CHAT_BASE_URL=https://api.deepseek.com
LLM_CHAT_MODEL=deepseek-chat

# 阿里 Qwen（可选）— https://dashscope.console.aliyun.com/apiKey
# LLM_CHAT_API_KEY=your-qwen-api-key-here
# LLM_CHAT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_CHAT_MODEL=qwen-plus

# OpenAI（可选）
# LLM_CHAT_API_KEY=your-openai-api-key-here
# LLM_CHAT_BASE_URL=https://api.openai.com/v1
# LLM_CHAT_MODEL=gpt-4o

LLM_CHAT_TEMPERATURE=0.3
LLM_CHAT_MAX_TOKENS=8192
LLM_CHAT_TIMEOUT=120.0
LLM_CHAT_STREAMING=true
LLM_CHAT_MAX_TOOL_ROUNDS=20

# ── Embedding 配置（本地 sentence-transformers，无需 API Key）──
# 模型约 80MB，首次使用时自动从 HuggingFace 下载
# 国内用户建议设置 HF_ENDPOINT 切换镜像加速下载
LLM_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
HF_ENDPOINT=https://hf-mirror.com
HF_HUB_ENABLE_HF_TRANSFER=0

# ── 记忆系统 ──
MEMORY_SQLITE_PATH=data/memory.db

# ── Agent 行为 ──
# DEV_AGENT_WORKSPACE 留空时使用当前目录；
# Sage 工作空间通过 /api/sage/workspaces 创建后自动切换，无需手动设置
DEV_AGENT_WORKSPACE=.
DEV_AGENT_MAX_CONTEXT_TOKENS=60000
DEV_AGENT_SUMMARY_TRIGGER_TOKENS=45000

# ── 联网搜索（可选，用于外部文献检索）──
# Tavily AI: 专为 AI 设计的搜索 API，每月 1000 次免费额度
# 获取地址: https://tavily.com
TAVILY_API_KEY=

# ── Sage 工作空间说明 ──
# Sage 工作空间存储在项目根目录的 workspaces/ 下
# 每个工作空间按 "时间戳_领域标签" 命名，例如：
#   workspaces/20260721_143022_CS-AI/
#   workspaces/20260721_150000_MED-Cardio/
#   workspaces/20260721_160000_SSCI-PSY/
#
# 创建工作空间：
#   POST /api/sage/workspaces  body: {"domain_tag": "CS-AI", "index_level": "SCI"}
# 导入论文（文件夹）：
#   POST /api/sage/workspaces/{ws_id}/import-folder  body: {"source_path": "/path/to/papers"}
# 上传论文（单文件）：
#   POST /api/sage/workspaces/{ws_id}/upload  form: file=...
# 切换工作空间：
#   POST /api/sage/workspaces/{ws_id}/switch
